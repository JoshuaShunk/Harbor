{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Harbor",
  "version": "0.5.4",
  "identifier": "com.harbor.desktop",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "binaries/harbor": "harbor"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Harbor",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/JoshuaShunk/Harbor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2RTBEMThCNzUwRjc1MTgKUldRWWRROTFpOUhnTmhvYVR4TFdKNUo2VUk5ZUdUWFg5amhxQWo5U2VGc2xpQnFCSThySmRINVkK"
    }
  }
}
